<div class="auth-container">
  <div class="auth-box">
    <h1>Welcome to JobHunter</h1>
    
    <%= form_with(scope: :session, url: login_path, local: true, class: "auth-form") do |f| %>
      <div class="form-group">
        <%= f.label :email, class: "form-label" %>
        <%= f.email_field :email, class: "form-input", required: true %>
      </div>

      <div class="form-group">
        <%= f.label :password, class: "form-label" %>
        <%= f.password_field :password, class: "form-input", required: true %>
      </div>

      <%= f.submit "Log In", class: "form-submit" %>
    <% end %>

    <div class="auth-links">
      <p>Don't have an account? <%= link_to "Sign up", signup_path, class: "auth-link" %></p>
    </div>
  </div>
</div> 