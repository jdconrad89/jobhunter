<%= form_with(model: job_search, local: true, class: "job-search-form", data: { action: "submit->job-search#validateForm" }) do |f| %>
  <% if job_search.errors.any? %>
    <div class="error-messages">
      <h2><%= pluralize(job_search.errors.count, "error") %> prohibited this job search from being saved:</h2>
      <ul>
        <% job_search.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :job_title, class: "form-label" %>
    <%= f.text_field :job_title, class: "form-input", placeholder: "e.g., Software Engineer" %>
  </div>

  <div class="form-group">
    <%= f.label :location, class: "form-label" %>
    <%= f.text_field :location, class: "form-input", placeholder: "e.g., San Francisco, CA" %>
  </div>

  <div class="form-group">
    <%= f.label :remote, class: "form-label" %>
    <%= f.check_box :remote, class: "form-checkbox" %>
    <span>Include remote positions</span>
  </div>

  <div class="form-group">
    <%= f.label :language_code, class: "form-label" %>
    <%= f.text_field :language_code, class: "form-input", placeholder: "e.g., en-US" %>
  </div>

  <div class="form-group">
    <%= f.label :runtime, "Daily Run Time", class: "form-label" %>
    <%= f.time_field :runtime, class: "form-input" %>
  </div>

  <div class="form-group">
    <%= f.label :timezone, class: "form-label" %>
    <%= f.select :timezone,
        ActiveSupport::TimeZone.all.map { |tz| [tz.name, tz.name] },
        { include_blank: "Select a timezone" },
        { class: "form-input" } %>
  </div>

  <div class="form-group">
    <%= f.label :board_relevance, "Preferred job boards (in order)", class: "form-label" %>
    <p class="form-helper-text">
      Enter names as they appear on &ldquo;Apply&rdquo; links in Google Jobs (e.g. LinkedIn, Indeed, ZipRecruiter).
      Earlier boards are preferred when a listing has multiple apply options.
    </p>
    <div id="board-relevance-fields" data-job-search-target="boardRelevanceContainer">
      <% board_names = job_search.board_relevance.presence || [ nil ] %>
      <% board_names.each do |board_name| %>
        <div class="board-relevance-row">
          <div class="url-input-group">
            <div class="board-relevance-row__inputs">
              <%= text_field_tag "job_search[board_relevance][]", board_name,
                  class: "form-input board-name-input",
                  data: { job_search_target: "boardNameInput" },
                  placeholder: "e.g. LinkedIn",
                  maxlength: 255 %>
              <% if board_names.length > 1 %>
                <button type="button"
                        class="form-submit remove-url-button"
                        data-action="click->job-search#removeBoardRow">Remove</button>
              <% end %>
            </div>
            <div class="board-relevance-hint"></div>
          </div>
        </div>
      <% end %>
    </div>
    <button type="button"
            id="add-board-entry"
            class="form-submit secondary-button"
            data-job-search-target="addButton"
            data-action="click->job-search#addBoardRow">Add another board</button>
    <div id="board-limit-message"
         class="error-message"
         data-job-search-target="limitMessage"
         style="display: none;">Maximum 10 boards allowed</div>
  </div>

  <div class="form-group">
    <%= f.submit submit_label, class: "form-submit" %>
  </div>
<% end %>

<style>
  .url-input-group {
    position: relative;
    margin-bottom: 0.5rem;
  }

  .board-relevance-row__inputs {
    display: flex;
    gap: 0.5rem;
  }

  .board-relevance-hint {
    font-size: 0.875rem;
    margin-top: 0.25rem;
    min-height: 1.25rem;
  }

  .board-relevance-hint.error {
    color: #dc2626;
  }

  .secondary-button {
    background-color: #6b7280;
  }

  .secondary-button:hover {
    background-color: #4b5563;
  }

  .form-helper-text {
    color: #6b7280;
    font-size: 0.875rem;
    margin-bottom: 0.5rem;
  }

  .remove-url-button {
    background-color: #dc2626;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
  }

  .remove-url-button:hover {
    background-color: #b91c1c;
  }
</style>
