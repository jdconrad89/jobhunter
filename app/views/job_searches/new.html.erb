<div class="form-container" data-controller="job-search">
  <h1>Create New Job Search</h1>

  <%= form_with(model: @job_search, local: true, class: "job-search-form", data: { action: "submit->job-search#validateForm" }) do |f| %>
    <% if @job_search.errors.any? %>
      <div class="error-messages">
        <h2><%= pluralize(@job_search.errors.count, "error") %> prohibited this job search from being saved:</h2>
        <ul>
          <% @job_search.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-group">
      <%= f.label :job_title, class: "form-label" %>
      <%= f.text_field :job_title, class: "form-input", placeholder: "e.g., Software Engineer" %>
    </div>

    <div class="form-group">
      <%= f.label :location, class: "form-label" %>
      <%= f.text_field :location, class: "form-input", placeholder: "e.g., San Francisco, CA" %>
    </div>

    <div class="form-group">
      <%= f.label :remote, class: "form-label" %>
      <%= f.check_box :remote, class: "form-checkbox" %>
      <span>Include remote positions</span>
    </div>

    <div class="form-group">
      <%= f.label :language_code, class: "form-label" %>
      <%= f.text_field :language_code, class: "form-input", placeholder: "e.g., en-US" %>
    </div>

    <div class="form-group">
      <%= f.label :runtime, "Daily Run Time", class: "form-label" %>
      <%= f.time_field :runtime, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= f.label :timezone, class: "form-label" %>
      <%= f.select :timezone, 
          ActiveSupport::TimeZone.all.map { |tz| [tz.name, tz.name] },
          { include_blank: "Select a timezone" },
          { class: "form-input" } %>
    </div>

    <div class="form-group">
      <%= f.label :board_relevance, "Job Board URLs", class: "form-label" %>
      <p class="form-helper-text">Add URLs for job boards you want to search. Each URL must start with http:// or https://</p>
      <div id="board-urls" data-job-search-target="urlContainer">
        <div class="board-url-input">
          <div class="url-input-group">
            <%= text_field_tag "job_search[board_relevance][]", nil, 
                class: "form-input url-input", 
                data: { job_search_target: "urlInput" },
                placeholder: "https://www.linkedin.com/jobs/search/",
                pattern: "^https?://.+",
                title: "URL must start with http:// or https://" %>
            <div class="url-validation-message"></div>
          </div>
        </div>
      </div>
      <button type="button" 
              id="add-url" 
              class="form-submit secondary-button" 
              data-job-search-target="addButton"
              data-action="click->job-search#addUrl">Add Another URL</button>
      <div id="url-limit-message" 
           class="error-message" 
           data-job-search-target="limitMessage" 
           style="display: none;">Maximum 10 URLs allowed</div>
    </div>

    <div class="form-group">
      <%= f.submit "Create Job Search", class: "form-submit" %>
    </div>
  <% end %>
</div>

<style>
  .url-input-group {
    position: relative;
    margin-bottom: 0.5rem;
  }

  .url-validation-message {
    font-size: 0.875rem;
    margin-top: 0.25rem;
    min-height: 1.25rem;
  }

  .url-validation-message.error {
    color: #dc2626;
  }

  .url-validation-message.success {
    color: #059669;
  }

  .secondary-button {
    background-color: #6b7280;
  }

  .secondary-button:hover {
    background-color: #4b5563;
  }

  .form-helper-text {
    color: #6b7280;
    font-size: 0.875rem;
    margin-bottom: 0.5rem;
  }

  .remove-url-button {
    background-color: #dc2626;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
  }

  .remove-url-button:hover {
    background-color: #b91c1c;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const addUrlButton = document.getElementById('add-url');
    const boardUrls = document.getElementById('board-urls');
    const urlLimitMessage = document.getElementById('url-limit-message');
    const MAX_URLS = 10;

    function validateUrl(input) {
      const url = input.value.trim();
      const message = input.parentElement.querySelector('.url-validation-message');
      
      if (!url) {
        message.textContent = '';
        message.className = 'url-validation-message';
        return true;
      }

      try {
        new URL(url);
        if (url.startsWith('http://') || url.startsWith('https://')) {
          message.textContent = '✓ Valid URL';
          message.className = 'url-validation-message success';
          return true;
        } else {
          message.textContent = 'URL must start with http:// or https://';
          message.className = 'url-validation-message error';
          return false;
        }
      } catch {
        message.textContent = 'Please enter a valid URL';
        message.className = 'url-validation-message error';
        return false;
      }
    }

    function createUrlInput() {
      const newInput = document.createElement('div');
      newInput.className = 'board-url-input';
      newInput.innerHTML = `
        <div class="url-input-group">
          <div style="display: flex; gap: 0.5rem;">
            <input type="text" 
                   name="job_search[board_relevance][]" 
                   class="form-input url-input" 
                   placeholder="https://www.linkedin.com/jobs/search/"
                   pattern="^https?://.+"
                   title="URL must start with http:// or https://">
            <button type="button" class="form-submit remove-url-button" onclick="this.closest('.board-url-input').remove(); updateAddButton()">Remove</button>
          </div>
          <div class="url-validation-message"></div>
        </div>
      `;

      const input = newInput.querySelector('input');
      input.addEventListener('input', () => validateUrl(input));
      input.addEventListener('blur', () => validateUrl(input));

      return newInput;
    }

    function updateAddButton() {
      const currentUrls = boardUrls.querySelectorAll('.board-url-input').length;
      if (currentUrls >= MAX_URLS) {
        addUrlButton.style.display = 'none';
        urlLimitMessage.style.display = 'block';
      } else {
        addUrlButton.style.display = 'block';
        urlLimitMessage.style.display = 'none';
      }
    }

    addUrlButton.addEventListener('click', function() {
      const currentUrls = boardUrls.querySelectorAll('.board-url-input').length;
      if (currentUrls < MAX_URLS) {
        boardUrls.appendChild(createUrlInput());
        updateAddButton();
      }
    });

    // Initialize validation for the first URL input
    const firstInput = boardUrls.querySelector('.url-input');
    if (firstInput) {
      firstInput.addEventListener('input', () => validateUrl(firstInput));
      firstInput.addEventListener('blur', () => validateUrl(firstInput));
    }

    // Add form submission validation
    document.querySelector('form').addEventListener('submit', function(e) {
      const urlInputs = document.querySelectorAll('.url-input');
      let isValid = true;

      urlInputs.forEach(input => {
        if (!validateUrl(input)) {
          isValid = false;
        }
      });

      if (!isValid) {
        e.preventDefault();
        alert('Please fix the invalid URLs before submitting.');
      }
    });
  });
</script>
