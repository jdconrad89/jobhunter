<% content_for :title, "Analytics" %>
<% content_for :head do %>
  <%= stylesheet_link_tag "analytics", "data-turbo-track": "reload" %>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<% end %>

<div class="analytics-page" data-analytics-page>
  <header class="analytics-page__header">
    <h1 class="analytics-page__title">Job Post Analytics</h1>
    <p class="analytics-page__subtitle">
      Insights from your saved job postings — experience requirements, in-demand skills, and salary distributions.
    </p>
  </header>

  <div class="analytics-page__stats">
    <div class="analytics-stat">
      <span class="analytics-stat__label">Total posts</span>
      <span class="analytics-stat__value"><%= @analytics.total_posts %></span>
    </div>
    <div class="analytics-stat">
      <span class="analytics-stat__label">With experience data</span>
      <span class="analytics-stat__value"><%= @analytics.posts_with_experience %></span>
    </div>
    <div class="analytics-stat">
      <span class="analytics-stat__label">With salary data</span>
      <span class="analytics-stat__value"><%= @analytics.posts_with_salary %></span>
    </div>
    <div class="analytics-stat">
      <span class="analytics-stat__label">Salary + experience</span>
      <span class="analytics-stat__value"><%= @analytics.salary_points.size %></span>
    </div>
  </div>

  <div class="analytics-page__grid">
    <section class="analytics-card">
      <header class="analytics-card__header">
        <h2 class="analytics-card__title">Experience requirements</h2>
        <p class="analytics-card__description">
          Job count by years of experience. Posts with overlapping ranges count toward each matching bucket.
        </p>
      </header>
      <% if @analytics.experience_breakdown.any? { |row| row[:count].positive? } %>
        <div class="analytics-card__chart">
          <canvas id="experience-chart"></canvas>
        </div>
      <% else %>
        <p class="analytics-empty">No experience data found in your job descriptions yet.</p>
      <% end %>
    </section>

    <section class="analytics-card">
      <header class="analytics-card__header">
        <h2 class="analytics-card__title">Most requested skills</h2>
        <p class="analytics-card__description">
          Skills detected in job titles and descriptions across your postings.
        </p>
      </header>
      <% if @analytics.top_skills.any? %>
        <div class="analytics-card__chart analytics-card__chart--skills">
          <canvas id="skills-chart"></canvas>
        </div>
      <% else %>
        <p class="analytics-empty">No skills detected yet. Add job posts with descriptions to see trends.</p>
      <% end %>
    </section>

    <section class="analytics-card analytics-card--wide">
      <header class="analytics-card__header">
        <h2 class="analytics-card__title">Salary &amp; experience distribution</h2>
        <p class="analytics-card__description">
          Explore how salary and experience requirements relate. Switch direction to filter by experience and see salaries,
          or filter by salary and see experience levels. Hover a bar for posting counts and percentages.
        </p>
      </header>

      <% if @analytics.salary_points.any? %>
        <div class="analytics-distribution-mode" role="tablist" aria-label="Distribution direction">
          <button type="button" class="analytics-distribution-mode__btn analytics-distribution-mode__btn--active" data-distribution-mode="experience-to-salary" role="tab" aria-selected="true">
            Experience → Salary
          </button>
          <button type="button" class="analytics-distribution-mode__btn" data-distribution-mode="salary-to-experience" role="tab" aria-selected="false">
            Salary → Experience
          </button>
        </div>

        <div class="analytics-range-controls" id="controls-experience-to-salary">
          <label>
            Minimum experience (years)
            <input type="range" id="experience-min" min="0" max="20" value="2" step="1" />
            <span id="experience-min-value">2</span> yrs
          </label>
          <label>
            Maximum experience (years)
            <input type="range" id="experience-max" min="0" max="20" value="8" step="1" />
            <span id="experience-max-value">8</span> yrs
          </label>
          <p class="analytics-range-summary" id="experience-to-salary-summary">
            Showing salary distribution for <strong>2–8 years</strong> of experience.
          </p>
        </div>

        <div class="analytics-range-controls" id="controls-salary-to-experience" hidden>
          <label>
            Minimum salary
            <input type="range" id="salary-min" min="50000" max="300000" value="100000" step="25000" />
            <span id="salary-min-value">$100k</span>
          </label>
          <label>
            Maximum salary
            <input type="range" id="salary-max" min="50000" max="300000" value="175000" step="25000" />
            <span id="salary-max-value">$175k</span>
          </label>
          <p class="analytics-range-summary" id="salary-to-experience-summary">
            Showing experience distribution for <strong>$100k–$175k</strong> salaries.
          </p>
        </div>

        <div class="analytics-card__chart analytics-card__chart--salary">
          <canvas id="distribution-chart"></canvas>
        </div>
      <% else %>
        <p class="analytics-empty">
          No postings with both salary and experience data yet. Salaries and experience are extracted from job descriptions.
        </p>
      <% end %>
    </section>
  </div>

  <section class="analytics-synopsis">
    <header class="analytics-synopsis__header">
      <h2 class="analytics-synopsis__title">Analysis synopsis</h2>
      <p class="analytics-synopsis__description">
        Auto-generated summary of your saved postings. Interactive charts above can be filtered further; this overview reflects your full dataset.
      </p>
    </header>

    <div class="analytics-synopsis__body">
      <% @synopsis.paragraphs.each do |paragraph| %>
        <p class="analytics-synopsis__paragraph"><%= paragraph %></p>
      <% end %>
    </div>
  </section>
</div>

<script id="analytics-data" type="application/json">
  <%= {
    experience: @analytics.experience_breakdown,
    skills: @analytics.top_skills,
    salaryPoints: @analytics.salary_points,
    experienceBuckets: JobPosts::Analytics::EXPERIENCE_BUCKETS.map { |bucket| bucket.slice(:label, :min, :max) },
    salaryConfig: {
      bucketSize: JobPosts::Analytics::SALARY_BUCKET_SIZE,
      rangeMin: JobPosts::Analytics::SALARY_RANGE_MIN,
      rangeMax: JobPosts::Analytics::SALARY_RANGE_MAX
    }
  }.to_json.html_safe %>
</script>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    if (typeof Chart === "undefined") return;

    const data = JSON.parse(document.getElementById("analytics-data").textContent);
    const brand = "#0d9488";
    const brandLight = "rgba(13, 148, 136, 0.15)";
    const brandDark = "#0f766e";

    const chartDefaults = {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false }
      }
    };

    if (data.experience?.some((row) => row.count > 0)) {
      new Chart(document.getElementById("experience-chart"), {
        type: "bar",
        data: {
          labels: data.experience.map((row) => row.label),
          datasets: [{
            data: data.experience.map((row) => row.count),
            backgroundColor: brand,
            borderRadius: 6
          }]
        },
        options: {
          ...chartDefaults,
          scales: {
            y: {
              beginAtZero: true,
              ticks: { precision: 0 },
              title: { display: true, text: "Job postings" }
            },
            x: {
              title: { display: true, text: "Years of experience" }
            }
          }
        }
      });
    }

    if (data.skills?.length) {
      new Chart(document.getElementById("skills-chart"), {
        type: "bar",
        data: {
          labels: data.skills.map((row) => row.skill),
          datasets: [{
            data: data.skills.map((row) => row.count),
            backgroundColor: brandDark,
            borderRadius: 6
          }]
        },
        options: {
          indexAxis: "y",
          ...chartDefaults,
          scales: {
            x: {
              beginAtZero: true,
              ticks: { precision: 0 },
              title: { display: true, text: "Mentions" }
            }
          }
        }
      });
    }

    if (!data.salaryPoints?.length) return;

    const SALARY_BUCKET_SIZE = data.salaryConfig.bucketSize;
    const SALARY_RANGE_MIN = data.salaryConfig.rangeMin;
    const SALARY_RANGE_MAX = data.salaryConfig.rangeMax;
    const EXPERIENCE_BUCKETS = data.experienceBuckets;

    const formatK = (amount) => (amount >= 1000 ? `${amount / 1000}k` : `${amount}`);
    const formatSalaryLabel = (min, max) =>
      max >= SALARY_RANGE_MAX ? `$${formatK(min)}+` : `$${formatK(min)}-${formatK(max)}`;
    const formatSalaryAmount = (amount) => `$${formatK(amount)}`;

    const rangesOverlap = (leftMin, leftMax, rightMin, rightMax) =>
      leftMin <= rightMax && leftMax >= rightMin;

    const percentagesFor = (counts, total) =>
      total > 0 ? counts.map((count) => Math.round((count / total) * 1000) / 10) : counts.map(() => 0);

    const salaryBuckets = () => {
      const buckets = [];
      let start = SALARY_RANGE_MIN;

      while (start < SALARY_RANGE_MAX) {
        const end = start + SALARY_BUCKET_SIZE - 1;
        buckets.push({ min: start, max: end, label: formatSalaryLabel(start, end) });
        start += SALARY_BUCKET_SIZE;
      }

      buckets.push({
        min: SALARY_RANGE_MAX,
        max: Number.POSITIVE_INFINITY,
        label: formatSalaryLabel(SALARY_RANGE_MAX, SALARY_RANGE_MAX + SALARY_BUCKET_SIZE - 1)
      });

      return buckets;
    };

    const distributeRangeAcrossBuckets = (rangeMin, rangeMax, buckets, onBucket) => {
      const clippedMin = Math.max(rangeMin, SALARY_RANGE_MIN);
      const clippedMax = Math.min(rangeMax, SALARY_RANGE_MAX);
      if (clippedMin > clippedMax) return;

      let bucketStart =
        Math.floor((clippedMin - SALARY_RANGE_MIN) / SALARY_BUCKET_SIZE) * SALARY_BUCKET_SIZE + SALARY_RANGE_MIN;

      while (bucketStart <= clippedMax) {
        const bucketEnd = bucketStart + SALARY_BUCKET_SIZE - 1;
        if (rangesOverlap(rangeMin, rangeMax, bucketStart, bucketEnd)) {
          onBucket(formatSalaryLabel(bucketStart, bucketEnd));
        }
        bucketStart += SALARY_BUCKET_SIZE;
      }
    };

    const computeSalaryDistribution = (points, experienceMin, experienceMax) => {
      const expMin = Math.min(experienceMin, experienceMax);
      const expMax = Math.max(experienceMin, experienceMax);
      const buckets = salaryBuckets();
      const counts = Object.fromEntries(buckets.map((bucket) => [bucket.label, 0]));
      let matchingPosts = 0;

      points.forEach((point) => {
        if (!rangesOverlap(point.exp_min, point.exp_max, expMin, expMax)) return;

        matchingPosts += 1;
        distributeRangeAcrossBuckets(point.pay_min, point.pay_max, buckets, (label) => {
          if (counts[label] !== undefined) counts[label] += 1;
        });
      });

      const countValues = buckets.map((bucket) => counts[bucket.label]);
      const percentages = percentagesFor(countValues, matchingPosts);

      return {
        labels: buckets.map((bucket) => bucket.label),
        counts: countValues,
        percentages,
        matchingPosts,
        xTitle: "Annual salary (USD)",
        yTitle: "Job postings in salary band",
        skipTicks: true
      };
    };

    const computeExperienceDistribution = (points, salaryMin, salaryMax) => {
      const payMin = Math.min(salaryMin, salaryMax);
      const payMax = Math.max(salaryMin, salaryMax);
      const counts = Object.fromEntries(EXPERIENCE_BUCKETS.map((bucket) => [bucket.label, 0]));
      let matchingPosts = 0;

      points.forEach((point) => {
        if (!rangesOverlap(point.pay_min, point.pay_max, payMin, payMax)) return;

        matchingPosts += 1;
        EXPERIENCE_BUCKETS.forEach((bucket) => {
          if (rangesOverlap(point.exp_min, point.exp_max, bucket.min, bucket.max)) {
            counts[bucket.label] += 1;
          }
        });
      });

      const labels = EXPERIENCE_BUCKETS.map((bucket) => bucket.label);
      const countValues = labels.map((label) => counts[label]);
      const percentages = percentagesFor(countValues, matchingPosts);

      return {
        labels,
        counts: countValues,
        percentages,
        matchingPosts,
        xTitle: "Years of experience",
        yTitle: "Job postings in experience band",
        skipTicks: false
      };
    };

    const modeButtons = document.querySelectorAll("[data-distribution-mode]");
    const controlsExperienceToSalary = document.getElementById("controls-experience-to-salary");
    const controlsSalaryToExperience = document.getElementById("controls-salary-to-experience");
    const experienceMinInput = document.getElementById("experience-min");
    const experienceMaxInput = document.getElementById("experience-max");
    const experienceMinValue = document.getElementById("experience-min-value");
    const experienceMaxValue = document.getElementById("experience-max-value");
    const experienceToSalarySummary = document.getElementById("experience-to-salary-summary");
    const salaryMinInput = document.getElementById("salary-min");
    const salaryMaxInput = document.getElementById("salary-max");
    const salaryMinValue = document.getElementById("salary-min-value");
    const salaryMaxValue = document.getElementById("salary-max-value");
    const salaryToExperienceSummary = document.getElementById("salary-to-experience-summary");
    const distributionCanvas = document.getElementById("distribution-chart");

    let distributionMode = "experience-to-salary";
    let distributionChart;

    const tooltipLabel = (context, distribution) => {
      const count = context.parsed.y ?? 0;
      const pct = distribution.percentages[context.dataIndex] ?? 0;
      return `${context.dataset.label}: ${count} posting${count === 1 ? "" : "s"} (${pct}%)`;
    };

    const renderDistributionChart = () => {
      let distribution;

      if (distributionMode === "experience-to-salary") {
        let expMin = parseInt(experienceMinInput.value, 10);
        let expMax = parseInt(experienceMaxInput.value, 10);

        if (expMin > expMax) {
          [expMin, expMax] = [expMax, expMin];
          experienceMinInput.value = expMin;
          experienceMaxInput.value = expMax;
        }

        experienceMinValue.textContent = expMin;
        experienceMaxValue.textContent = expMax;

        distribution = computeSalaryDistribution(data.salaryPoints, expMin, expMax);
        experienceToSalarySummary.innerHTML =
          `Showing salary distribution for <strong>${expMin}–${expMax} years</strong> of experience ` +
          `(<strong>${distribution.matchingPosts}</strong> matching postings).`;
      } else {
        let payMin = parseInt(salaryMinInput.value, 10);
        let payMax = parseInt(salaryMaxInput.value, 10);

        if (payMin > payMax) {
          [payMin, payMax] = [payMax, payMin];
          salaryMinInput.value = payMin;
          salaryMaxInput.value = payMax;
        }

        salaryMinValue.textContent = formatSalaryAmount(payMin);
        salaryMaxValue.textContent = formatSalaryAmount(payMax);

        distribution = computeExperienceDistribution(data.salaryPoints, payMin, payMax);
        salaryToExperienceSummary.innerHTML =
          `Showing experience distribution for <strong>${formatSalaryAmount(payMin)}–${formatSalaryAmount(payMax)}</strong> salaries ` +
          `(<strong>${distribution.matchingPosts}</strong> matching postings).`;
      }

      const chartData = {
        labels: distribution.labels,
        datasets: [
          {
            type: "bar",
            label: "Job postings",
            data: distribution.counts,
            backgroundColor: brand,
            borderRadius: 4,
            order: 2
          },
          {
            type: "line",
            label: "Distribution curve",
            data: distribution.counts,
            borderColor: "#2563eb",
            backgroundColor: brandLight,
            fill: true,
            tension: 0.45,
            pointRadius: 3,
            pointBackgroundColor: "#2563eb",
            order: 1
          }
        ]
      };

      const chartOptions = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: true, position: "top" },
          tooltip: {
            callbacks: {
              title: (items) => distribution.labels[items[0]?.dataIndex] ?? "",
              label: (context) => tooltipLabel(context, distribution)
            }
          }
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: { precision: 0 },
            title: { display: true, text: distribution.yTitle }
          },
          x: {
            title: { display: true, text: distribution.xTitle },
            ticks: {
              maxRotation: distribution.skipTicks ? 45 : 0,
              minRotation: distribution.skipTicks ? 45 : 0,
              autoSkip: distribution.skipTicks,
              font: { size: 11 }
            }
          }
        }
      };

      if (distributionChart) {
        distributionChart.data = chartData;
        distributionChart.options = chartOptions;
        distributionChart.update();
        return;
      }

      distributionChart = new Chart(distributionCanvas, {
        type: "bar",
        data: chartData,
        options: chartOptions
      });
    };

    const setDistributionMode = (mode) => {
      distributionMode = mode;
      modeButtons.forEach((button) => {
        const active = button.dataset.distributionMode === mode;
        button.classList.toggle("analytics-distribution-mode__btn--active", active);
        button.setAttribute("aria-selected", active ? "true" : "false");
      });
      controlsExperienceToSalary.hidden = mode !== "experience-to-salary";
      controlsSalaryToExperience.hidden = mode !== "salary-to-experience";
      renderDistributionChart();
    };

    modeButtons.forEach((button) => {
      button.addEventListener("click", () => setDistributionMode(button.dataset.distributionMode));
    });

    experienceMinInput.addEventListener("input", () => {
      if (distributionMode === "experience-to-salary") renderDistributionChart();
    });
    experienceMaxInput.addEventListener("input", () => {
      if (distributionMode === "experience-to-salary") renderDistributionChart();
    });
    salaryMinInput.addEventListener("input", () => {
      if (distributionMode === "salary-to-experience") renderDistributionChart();
    });
    salaryMaxInput.addEventListener("input", () => {
      if (distributionMode === "salary-to-experience") renderDistributionChart();
    });
    setDistributionMode("experience-to-salary");
  });
</script>
