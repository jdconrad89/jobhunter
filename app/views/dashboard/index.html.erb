<% content_for :head do %>
  <%= stylesheet_link_tag "dashboard", "data-turbo-track": "reload" %>
<% end %>

<div class="dashboard-page">
  <header class="dashboard-page__header">
    <div>
      <h1 class="dashboard-page__title">Your Job Searches</h1>
      <p class="dashboard-page__subtitle">Manage automated searches and review recent applications.</p>
    </div>
    <%= link_to "New Job Search", new_job_search_path, class: "dashboard-page__cta" %>
  </header>

  <div class="dashboard-page__grid">
    <% @job_searches.each do |job_search| %>
      <article class="job-search-card">
        <div class="job-search-card__header">
          <h2 class="job-search-card__title"><%= job_search.job_title %></h2>
          <% if job_search.location.present? %>
            <span class="job-search-card__badge job-search-card__badge--location"><%= job_search.location %></span>
          <% end %>
        </div>

        <dl class="job-search-card__details">
          <div>
            <dt>Remote</dt>
            <dd><%= job_search.remote ? "Yes" : "No" %></dd>
          </div>
          <div>
            <dt>Language</dt>
            <dd><%= job_search.language_code %></dd>
          </div>
          <div>
            <dt>Run time</dt>
            <dd><%= job_search.runtime&.strftime("%I:%M %p") || "—" %></dd>
          </div>
          <div>
            <dt>Timezone</dt>
            <dd><%= job_search.timezone %></dd>
          </div>
        </dl>

        <div class="job-search-card__actions">
          <% unless job_search.manual? %>
            <%= button_to "Trigger Search",
                trigger_job_search_path(job_search),
                method: :post,
                class: "job-search-card__btn job-search-card__btn--primary",
                data: { turbo_confirm: "Are you sure you want to trigger this job search now?" } %>
            <%= link_to "Edit", edit_job_search_path(job_search), class: "job-search-card__link" %>
            <%= button_to "Delete",
                job_search_path(job_search),
                method: :delete,
                class: "job-search-card__btn job-search-card__btn--danger",
                data: { turbo_confirm: "Are you sure you want to delete this job search?" } %>
          <% else %>
            <span class="job-search-card__manual-label">Manual entry search</span>
          <% end %>
        </div>
      </article>
    <% end %>
  </div>

  <section class="dashboard-applications">
    <header class="dashboard-applications__header">
      <div>
        <h2 class="dashboard-applications__title">Recent Applications</h2>
        <% if @applications_total_count.positive? %>
          <p class="dashboard-applications__subtitle">
            Showing <%= @job_applications.size %> of <%= @applications_total_count %> applications.
            Track pipeline status on the application board.
          </p>
        <% else %>
          <p class="dashboard-applications__subtitle">Track pipeline status on the application board.</p>
        <% end %>
      </div>
      <div class="dashboard-applications__header-actions">
        <% if @applications_total_count.positive? %>
          <%= form_with url: dashboard_path, method: :get, local: true, class: "dashboard-applications__limit-form" do %>
            <label for="applications_limit" class="dashboard-applications__limit-label">Show</label>
            <select
              name="applications_limit"
              id="applications_limit"
              class="dashboard-applications__limit-select"
              onchange="this.form.requestSubmit()"
            >
              <% DashboardController::APPLICATION_LIMIT_OPTIONS.each do |limit| %>
                <option value="<%= limit %>" <%= "selected" if limit == @applications_limit %>><%= limit %></option>
              <% end %>
            </select>
            <span class="dashboard-applications__limit-suffix">recent</span>
          <% end %>
        <% end %>
        <%= link_to "Application Board", job_applications_path, class: "dashboard-page__cta dashboard-page__cta--secondary" %>
      </div>
    </header>

    <% if @job_applications.any? %>
      <div class="dashboard-applications__grid">
        <% @job_applications.each do |application| %>
          <% job = application.job_post %>
          <article class="dashboard-app-card">
            <div class="dashboard-app-card__header">
              <h3 class="dashboard-app-card__title"><%= job.title %></h3>
              <p class="dashboard-app-card__company"><%= job.company.name %></p>
            </div>

            <div class="dashboard-app-card__badges">
              <span class="dashboard-app-card__badge dashboard-app-card__badge--<%= application.status %>">
                <%= application.status.titleize %>
              </span>
              <% if job.remote %>
                <span class="dashboard-app-card__badge dashboard-app-card__badge--remote">Remote</span>
              <% end %>
              <% if job.location.present? %>
                <span class="dashboard-app-card__badge dashboard-app-card__badge--location"><%= job.location %></span>
              <% end %>
            </div>

            <dl class="dashboard-app-card__details">
              <div>
                <dt>Applied</dt>
                <dd><%= application.applied_at.strftime("%B %d, %Y") %></dd>
              </div>
            </dl>

            <div class="dashboard-app-card__actions">
              <%= link_to "View details", job_application_path(application), class: "dashboard-app-card__link" %>
              <%= link_to "Update status", edit_job_application_path(application), class: "dashboard-app-card__link dashboard-app-card__link--muted" %>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="dashboard-empty">
        <p>You haven't applied to any jobs yet.</p>
        <%= link_to "Browse job posts", job_posts_path, class: "dashboard-page__cta" %>
      </div>
    <% end %>
  </section>
</div>
